# Environment variables for LightningEmpire

# --- Database Configuration ---
# Example for PostgreSQL: DB_URL="postgresql://user:password@host:port/dbname"
# Example for SQLite: DB_URL="sqlite:///./lightning.db"
DB_URL="sqlite:///./lightning.db"

# --- API Keys ---
# Used for integrating with external dispatch platforms
UBER_API_TOKEN="YOUR_UBER_API_TOKEN_HERE"
FOODPANDA_API_TOKEN="YOUR_FOODPANDA_API_TOKEN_HERE"

# --- Telegram Bot Configuration ---
# Token for the main Telegram bot used in /tasks/telegram_bot.py
TELEGRAM_BOT_TOKEN="YOUR_TELEGRAM_BOT_TOKEN_HERE"
TELEGRAM_CHAT_ID="YOUR_ADMIN_CHAT_ID_HERE"

# --- AI Core Configuration ---
# Optional: API keys if using external AI services
OPENAI_API_KEY="YOUR_OPENAI_API_KEY_HERE"
GROK_API_KEY="YOUR_GROK_API_KEY_HERE"
