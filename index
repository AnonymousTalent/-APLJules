AICompanionController.csusing System.Collections;
using UnityEngine;
using UnityEngine.Networking;
using System.Text;
using Newtonsoft.Json.Linq;

public class AICompanionController : MonoBehaviour
{
    [Header("Player reference")]
    public Transform player;

    [Header("Movement settings")]
    public float followDistance = 3f;
    public float moveSpeed = 3f;

    [Header("Server config")]
    public string apiUrl = "https://api.stormai.world/ai/companion";
    public float pingInterval = 1.0f; // seconds

    private string currentAction = "idle";
    private Coroutine pingRoutine;

    void Start()
    {
        if (player == null)
        {
            Debug.LogError("AICompanionController: Player not assigned!");
            return;
        }

        pingRoutine = StartCoroutine(PingServerLoop());
    }

    IEnumerator PingServerLoop()
    {
        while (true)
        {
            yield return PingServer();
            yield return new WaitForSeconds(pingInterval);
        }
    }

    IEnumerator PingServer()
    {
        var payload = new JObject
        {
            ["player_distance"] = Vector3.Distance(transform.position, player.position),
            ["player_pos"] = new JObject { ["x"] = player.position.x, ["y"] = player.position.y, ["z"] = player.position.z },
            ["companion_pos"] = new JObject { ["x"] = transform.position.x, ["y"] = transform.position.y, ["z"] = transform.position.z },
            ["last_action"] = currentAction
        };

        var json = Encoding.UTF8.GetBytes(payload.ToString());
        using (UnityWebRequest req = new UnityWebRequest(apiUrl, "POST"))
        {
            req.uploadHandler = new UploadHandlerRaw(json);
            req.downloadHandler = new DownloadHandlerBuffer();
            req.SetRequestHeader("Content-Type", "application/json");
            yield return req.SendWebRequest();

            if (req.result == UnityWebRequest.Result.Success)
            {
                try
                {
                    var response = JObject.Parse(req.downloadHandler.text);
                    string action = response["action"]?.ToString() ?? "idle";
                    ApplyDecision(action);
                }
                catch (System.Exception e)
                {
                    Debug.LogWarning($"AICompanionController: parse error {e.Message}");
                }
            }
            else
            {
                Debug.LogWarning($"AICompanionController: ping failed {req.error}");
            }
        }
    }

    void ApplyDecision(string action)
    {
        currentAction = action;
        switch (action)
        {
            case "follow":
                Vector3 dir = player.position - transform.position;
                if (dir.magnitude > followDistance)
                    transform.position += dir.normalized * moveSpeed * Time.deltaTime;
                break;
            case "attack":
                Debug.Log("AI Companion attacking target!");
                break;
            case "idle":
            default:
                // stand still
                break;
        }
    }

    void OnDestroy()
    {
        if (pingRoutine != null)
            StopCoroutine(pingRoutine);
    }
